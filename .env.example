# Runtime
EDUAGENT_ENV=development
EDUAGENT_HOST=127.0.0.1
EDUAGENT_PORT=8000
DATABASE_URL=sqlite:///./data/eduagent.db
EDUAGENT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Strict fallback mode names are frozen by api-contract-v0.1.
EDUAGENT_PROFILE_MODE=development_heuristic
EDUAGENT_PLANNER_MODE=development_rule_based

# Never commit a real key. Set ENABLE_LLM=false for deterministic local fallback.
ENABLE_LLM=true
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# Process-local reviewed resource cache. Set regenerate=true in the API request
# to bypass and refresh a matching entry.
EDUAGENT_RESOURCE_CACHE_ENABLED=true
EDUAGENT_RESOURCE_CACHE_TTL_SECONDS=1800
EDUAGENT_RESOURCE_CACHE_MAX_ENTRIES=128
